# VRAGENT secrets — copy to home\.env and fill in. NEVER commit the filled file.
# Only the keys you actually use are needed; provider is auto-detected.
# IMPORTANT: no inline comments after a KEY= line — the value runs to end of line.

# --- LLM providers (set at least one) ---
# OpenRouter: one key unlocks 200+ models (recommended default gateway)
OPENROUTER_API_KEY=
# Optional: Claude direct (switch with `hermes model`)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# NOUS_API_KEY=

# --- Integrations (filled in Phase 3) ---
# kc_live_... from KarbonCopy Settings, API Keys
KARBONCOPY_API_KEY=
# for marketing media skills
PIXIO_API_KEY=

# --- Slack gateway (filled in Phase 6) ---
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_ALLOWED_USERS=

# --- Web search (optional; DuckDuckGo backend needs no key) ---
# EXA_API_KEY=
# TAVILY_API_KEY=
