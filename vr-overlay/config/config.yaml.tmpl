# =============================================================================
# RealDeal CPA — Hermes config TEMPLATE (source of truth).
# scripts\sync-overlay.ps1 renders this to %HERMES_HOME%\config.yaml, replacing
#   __VRAGENT_ROOT__  -> this project's absolute path (forward slashes)
# so it is portable across machines/usernames. Secrets live in home\.env.
# =============================================================================

# ---------------------------------------------------------------------------
# Model — multi-provider. OpenRouter is the broad gateway (one key → 200+
# models); Anthropic/Nous/OpenAI/etc. all work too. Switch live: `hermes model`.
# ---------------------------------------------------------------------------
model:
  # Strong reasoning for tax/consulting. Pick whatever your provider exposes —
  # switch anytime with `hermes model`. (claude-opus-4.5 is in Hermes' known list;
  # bump to a newer Opus if your OpenRouter/Anthropic catalog has one.)
  default: "anthropic/claude-opus-4.5"
  provider: "auto"                        # auto-detect from whichever keys are in home/.env
  base_url: "https://openrouter.ai/api/v1"

# ---------------------------------------------------------------------------
# Agent behavior — tuned for deep, multi-step professional work.
# ---------------------------------------------------------------------------
agent:
  max_turns: 90
  reasoning_effort: "high"
  verbose: false

# ---------------------------------------------------------------------------
# Terminal — local execution on this Windows machine.
# ---------------------------------------------------------------------------
terminal:
  backend: "local"
  cwd: "."
  timeout: 180
  home_mode: "auto"
  lifetime_seconds: 300

# ---------------------------------------------------------------------------
# Skills — domain pack lives in the tracked overlay (read-only external dir).
# Agent-authored skills still write to %HERMES_HOME%\skills.
# ---------------------------------------------------------------------------
skills:
  creation_nudge_interval: 8          # review/save skills more often (was 15) — learn faster
  external_dirs:
    - "__VRAGENT_ROOT__/vr-overlay/skills"

# ---------------------------------------------------------------------------
# Memory — cross-session learning. Agent curates MEMORY.md (its notes) and
# USER.md (about the firm) under home/memories. Seeded from vr-overlay/memory.
# ---------------------------------------------------------------------------
memory:
  memory_enabled: true
  user_profile_enabled: true          # build a USER.md model of the partner (off by default in core)
  memory_char_limit: 3000             # a pro agent accrues more durable firm facts (~1090 tokens)
  user_char_limit: 2000               # richer partner/preferences model (~725 tokens)
  nudge_interval: 6                   # remind to save memories every 6 turns (was 10)
  flush_min_turns: 3                  # save before context is lost sooner (was 6)
  # Memory provider: holographic is fully LOCAL (stdlib SQLite, no key, no paid service) and
  # adds semantic + compositional recall (fact_store/fact_feedback) on top of MEMORY.md/USER.md.
  # For dialectic cross-session user-modeling instead, set 'honcho' (needs honcho-ai + a key).
  provider: holographic

# ---------------------------------------------------------------------------
# Curator — background skill-library maintenance + consolidation into umbrellas.
# ---------------------------------------------------------------------------
curator:
  enabled: true
  interval_hours: 72
  min_idle_hours: 2                   # only run when genuinely idle, never mid-task
  stale_after_days: 45               # patient — pro skills (quarterly work) are used irregularly
  archive_after_days: 120            # don't archive a quarterly-tax skill at 90 days
  prune_builtins: true               # archive unused bundled skills too (recoverable)
  consolidate: true                   # LLM pass to merge overlapping skills into umbrellas

# ---------------------------------------------------------------------------
# Delegation — parallel subagents for big multi-part jobs (research, audits,
# batch bookkeeping). Cost scales with concurrency; kept sane + safe-by-default.
# ---------------------------------------------------------------------------
delegation:
  max_concurrent_children: 6
  max_spawn_depth: 2                  # allow orchestrator -> worker fan-out
  subagent_auto_approve: false        # never auto-approve dangerous cmds in children

# ---------------------------------------------------------------------------
# Toolsets — CLI gets the full power set (browser, code exec, delegation,
# session recall, vision/video, mixture-of-agents). Slack mirrors hermes-slack.
# A tool is only USED when relevant, so breadth here costs nothing idle.
# ---------------------------------------------------------------------------
platform_toolsets:
  cli: [hermes-cli, browser, code_execution, delegation, session_search, video, video_gen, moa]
  slack: [hermes-slack]

# ---------------------------------------------------------------------------
# MCP servers — external tools exposed to the agent. Launchers for external
# projects are rendered to home/launchers/ by sync-overlay.ps1 (they need a
# machine-specific PROJECTS_ROOT). Internal servers use the repo venv.
# ---------------------------------------------------------------------------
mcp_servers:
  # Windows GUI control (this repo's net-new server).
  desktop:
    command: "__VRAGENT_ROOT__/hermes-agent/.venv/Scripts/python.exe"
    args: ["__VRAGENT_ROOT__/vr-overlay/mcp/desktop-control/server.py"]
    timeout: 120

  # Bookkeeping — QuickBooks Desktop. Defaults to SAFE simulation mode.
  # Switch to live books by editing vr-overlay/mcp/launchers/quickbooks.cmd.tmpl.
  quickbooks:
    command: "cmd"
    args: ["/c", "__VRAGENT_ROOT__/home/launchers/quickbooks.cmd"]
    timeout: 180

  # Practice management — KarbonCopy (uses its own .env.local + SQLite db).
  karboncopy:
    command: "cmd"
    args: ["/c", "__VRAGENT_ROOT__/home/launchers/karboncopy.cmd"]
    timeout: 180

  # Bookkeeping ledger — VR-Ledger plain-text double-entry engine (in-process).
  vr-ledger:
    command: "__VRAGENT_ROOT__/hermes-agent/.venv/Scripts/python.exe"
    args: ["__VRAGENT_ROOT__/vr-overlay/mcp/vr-ledger/server.py"]
    timeout: 120

  # --- Staged (enable once prerequisites are met) -------------------------
  # Tax — Lacerte (LacertMCP, .NET). Needs the dotnet SDK + a built server.
  # Add launchers/lacerte.cmd.tmpl, then uncomment:
  # lacerte:
  #   command: "cmd"
  #   args: ["/c", "__VRAGENT_ROOT__/home/launchers/lacerte.cmd"]
  #   timeout: 180
  #
  # Tax research KB — tax-rag-app (FastAPI). Expose its API as an http MCP, then:
  # tax-rag:
  #   url: "http://127.0.0.1:8000/mcp"

# ---------------------------------------------------------------------------
# Display / branding — RealDeal CPA: black / white / green (Apple-clean).
# ---------------------------------------------------------------------------
display:
  compact: false
  tool_progress: all
  skin: realdealcpa          # CLI/TUI skin (vr-overlay/skins/realdealcpa.yaml)

dashboard:
  theme: realdealcpa         # web dashboard theme (vr-overlay/dashboard-themes/realdealcpa.yaml)
